{
    "expo": {
        "name": "Queue-Marshal",
        "slug": "queue-marshal",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./public/logo.jpg",
        "userInterfaceStyle": "dark",
        "splash": {
            "image": "./public/logo.jpg",
            "resizeMode": "contain",
            "backgroundColor": "#0f172a"
        },
        "assetBundlePatterns": [
            "**/*"
        ],
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.nabstertsr.queuemarshal"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./public/logo.jpg",
                "backgroundColor": "#0f172a"
            },
            "package": "com.nabstertsr.queuemarshal"
        },
        "web": {
            "favicon": "./public/logo.jpg"
        }
    }
}